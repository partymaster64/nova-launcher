{
  "productName": "Nova Launcher",
  "version": "0.1.0",
  "identifier": "dev.novalauncher.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nova Launcher",
        "width": 1100,
        "height": 700,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "Nova Launcher",
        "url": "/splashscreen.html",
        "width": 360,
        "height": 420,
        "resizable": false,
        "decorations": false,
        "center": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNCM0VDNzZFNEY2MkJGRDYKUldUV3YySlBic2MrT3lVbk1WSDc3VW1wZkV2eHlTNmc5a1V5YjRiMWtuVWdHWG1qaWpiaXRqdnYK",
      "endpoints": [
        "https://github.com/partymaster64/nova-launcher/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
